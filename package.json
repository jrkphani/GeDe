{
  "name": "gede",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "test": "vitest run",
    "e2e": "playwright test",
    "verify": "npm run typecheck && npm run lint && npm run lint:css && npm run test && npm run e2e",
    "verify:fast": "npm run typecheck && npm run lint && npm run lint:css && npm run test",
    "db:generate": "drizzle-kit generate",
    "db:migration-parity": "bash deploy/migration-parity/check-migrations.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint",
    "*.css": "stylelint"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electric-sql/pglite": "^0.3.0",
    "@fontsource-variable/inter": "^5.2.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.0",
    "@huggingface/transformers": "^4.2.0",
    "@radix-ui/react-popover": "^1.1.18",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-force": "^3.0.0",
    "d3-shape": "^3.2.0",
    "drizzle-orm": "^0.44.0",
    "lucide-react": "^1.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "uuidv7": "^1.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-force": "^3.0.10",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^26.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.0.0",
    "stylelint": "^17.14.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.0.0"
  }
}
