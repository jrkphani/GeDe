exports[`AuthStack (Gede-Test-Auth) — issue 033, ADR-0009 matches the snapshot 1`] = `
{
  "Description": "GeDe v2 identity: Cognito User Pool + public App Client (email/password, PKCE/SRP, no client secret) — issue 033 (ADR-0009), replacing the Api stack's former \`auth\` Fargate stub",
  "Outputs": {
