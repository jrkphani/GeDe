      "Export": {
        "Name": "Gede-Test-Auth-UserPoolId",
      },
      "Value": {
        "Ref": "UserPool6BA7E5F2",
      },
    },
    "UserPoolJwksUri": {
      "Description": "JWKS endpoint for validating the Cognito-issued JWT (RS256) - the seam 032 (sync/API) and 034 (RLS, keyed on the \`sub\` claim) validate against.",
      "Export": {
        "Name": "Gede-Test-Auth-UserPoolJwksUri",
      },
      "Value": {
        "Fn::Join": [
          "",
          [
