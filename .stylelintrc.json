{
  "plugins": ["stylelint-declaration-strict-value"],
  "rules": {
    "scale-unlimited/declaration-strict-value": [
      ["/color/", "fill", "stroke", "background"],
      {
        "ignoreValues": ["transparent", "currentColor", "inherit", "none", "unset", "initial"],
        "message": "Use a design token (var(--…) from tokens.css) instead of a hardcoded color."
      }
    ]
  },
  "ignoreFiles": ["dist/**", "dev-dist/**", "node_modules/**"]
}
