# GeDe — example environment variables (issue 044).
#
# Copy to `.env.local` (or `.env`) for a local build with live Cognito
# sign-in. Every variable here is OPTIONAL: the account-free local app
# (browser <-> PGlite) boots instantly with none of these set — auth is an
# on-ramp, not a gate (ADR-0009). This file documents shape only; it is not
# itself read by anything (`.gitignore` excludes real `.env*` files but keeps
# this example tracked).
#
# NOT SECRETS: a Cognito User Pool id and a public SPA App Client id are
# meant to ship inside a browser bundle — every Cognito JS SDK app inlines
# them. This app's User Pool Client has no client secret (PKCE, public
# client, `ALLOW_USER_SRP_AUTH` only — deploy/cdk/lib/auth-stack.ts); there is
# no credential to leak here. In CI (.github/workflows/deploy.yml) these three
# values are read from the `Gede-Test-Auth` CloudFormation stack's outputs at
# build time, never hardcoded.

# Cognito User Pool id (Auth stack output `UserPoolId`).
VITE_COGNITO_USER_POOL_ID=

# Cognito App Client id — the public SPA client, no secret (Auth stack
# output `UserPoolClientId`).
VITE_COGNITO_CLIENT_ID=

# AWS region the User Pool lives in. Defaults to us-east-1 if unset
# (src/auth/config.ts).
VITE_COGNITO_REGION=us-east-1

# Feature-flags the v2 cloud sync engine (issue 032). Default OFF — v1's
# single-user, no-network path is the tested default everywhere this is unset.
VITE_SYNC_ENABLED=

# The Electric read-path sync server's base URL (issue 032). Only consulted
# when VITE_SYNC_ENABLED=true.
VITE_SYNC_URL=

# The write-path API's endpoint (issue 048). Same-origin "/write" by default
# (deploy/cdk fronts both the static frontend and the write API behind one
# CloudFront distribution, DEPLOYMENT.md §9a) — only set this to point at a
# different origin/path in a non-standard environment.
VITE_WRITE_API_PATH=/write
